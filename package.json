{
  "name": "telegram-exchange-bot",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "tsc && node --env-file=.env dist/app.js",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "tsc && node dist/tests/runTests.js",
    "clean": "rm -rf dist",
    "cb": "npm run clean && npm run build",
    "w-clean": "if exist dist rmdir /s /q dist",
    "wcb": "npm run w-clean && npm run build",
    "wcbr": "npm run w-clean && npm run build && npm run dev"
  },
